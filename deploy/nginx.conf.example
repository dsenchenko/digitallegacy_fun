# Replace YOUR_DOMAIN with your domain, e.g. obs.example.com
# Install: sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/obs-menu
# Enable:  sudo ln -s /etc/nginx/sites-available/obs-menu /etc/nginx/sites-enabled/
# Test:    sudo nginx -t && sudo systemctl reload nginx
# TLS:     sudo certbot --nginx -d YOUR_DOMAIN

upstream obs_menu {
    server 127.0.0.1:3456;
    keepalive 32;
}

server {
    listen 80;
    server_name YOUR_DOMAIN;

    location / {
        proxy_pass http://obs_menu;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}

# After certbot, it will add a second server {} block for HTTPS on port 443.
# Admin cookies require HTTPS in production (Secure flag).
