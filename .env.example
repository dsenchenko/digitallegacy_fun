# Copy to .env and fill in before deploy
# cp .env.example .env

# Required for production — admin login if not set via first-visit setup.
# For local dev, leave commented out and set password on first /admin visit,
# or set your password here (this overrides any password saved in data/settings.json).
# ADMIN_PASSWORD=your-secure-password

# App bind (Docker sets these automatically)
HOST=0.0.0.0
PORT=3456

# Set to true when running behind nginx/Caddy/Cloudflare
TRUST_PROXY=true

# Docker Compose only — host port mapped to container :3456
# HOST_PORT=3456

# Node environment (set automatically in Docker)
# NODE_ENV=production
